# Firebase Client Configuration
# Public API key for Firebase client SDK (do not put real secrets in this file)
FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase auth domain from project settings
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase project identifier
FIREBASE_PROJECT_ID=your_project_id

# Firebase storage bucket (commonly *.appspot.com)
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Sender ID used for Firebase Cloud Messaging
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase app identifier for the client app
FIREBASE_APP_ID=your_app_id

# Optional Firebase Services
# Optional analytics measurement ID (if analytics is enabled)
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Expo Push Notifications
# Expo project ID used by expo-notifications
EXPO_PROJECT_ID=your_expo_project_id_here

# Environment
# Development environment for local runs
NODE_ENV=development
