rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    // Check if the user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the current user owns the user profile
    function isUserOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate that a pending invite exists for this user/guardian pair.
    function hasPendingInviteForPair(inviteId, userId, guardianId) {
      return isAuthenticated() &&
        inviteId is string &&
        request.auth.uid == guardianId &&
        request.auth.token.email is string &&
        exists(/databases/$(database)/documents/guardianInvites/$(inviteId)) &&
        get(/databases/$(database)/documents/guardianInvites/$(inviteId)).data.status == 'pending' &&
        get(/databases/$(database)/documents/guardianInvites/$(inviteId)).data.userId == userId &&
        get(/databases/$(database)/documents/guardianInvites/$(inviteId)).data.guardianEmail == request.auth.token.email;
    }

    // Check if the current user is a guardian of the specified user
    // Uses subcollection: users/{userId}/guardians/{guardianId}
    // The guardian document ID must match the guardian's auth UID
    function isGuardianOf(userId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userId)/guardians/$(request.auth.uid));
    }

    // Resolve canonical alert owner ID while remaining backward-compatible
    // with older documents that store userId instead of ownerId.
    function alertOwnerId(data) {
      return data.ownerId != null ? data.ownerId : data.userId;
    }

    // Generic ownership helper for alert-like docs.
    function isOwner(data) {
      return isAuthenticated() && request.auth.uid == alertOwnerId(data);
    }

    // Guardian helper for alert-like docs.
    function isGuardian(data) {
      let ownerId = alertOwnerId(data);
      return isAuthenticated() && ownerId != null &&
        exists(/databases/$(database)/documents/users/$(ownerId)/guardians/$(request.auth.uid));
    }

    // Police/authority role helper.
    // Supports custom claims, role in users/{uid}, OR profile in policeUsers/{uid}.
    function isPolice() {
      return isAuthenticated() && (
        request.auth.token.isPolice == true ||
        request.auth.token.role == 'police' ||
        request.auth.token.role == 'authority' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'police' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'authority'
          )
        ) ||
        exists(/databases/$(database)/documents/policeUsers/$(request.auth.uid))
      );
    }

    // Reusable helper to constrain mutable fields on updates.
    function onlyAllowedFieldsChanged(allowedKeys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedKeys);
    }

    // Alert create schema guard with backward compatibility:
    // - requires owner identity (ownerId or userId)
    // - requires createdAt and status
    // - requires location object OR latitude+longitude pair
    function hasRequiredAlertCreateFields() {
      let hasOwner = (
        request.resource.data.ownerId is string ||
        request.resource.data.userId is string
      );
      let hasTimestamp = request.resource.data.createdAt != null;
      let hasStatus = request.resource.data.status is string;
      let hasLocationObject = request.resource.data.location is map;
      let hasLatLng = (
        request.resource.data.latitude is number &&
        request.resource.data.longitude is number
      );

      return hasOwner && hasTimestamp && hasStatus && (hasLocationObject || hasLatLng);
    }

    // Escalation visibility helper for police reads.
    function isEscalatedAlert(data) {
      return (
        data.escalated == true ||
        data.escalationLevel is number && data.escalationLevel > 0 ||
        data.escalationState == 'completed' ||
        data.status == 'escalated'
      );
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // 1. Users Collection
    match /users/{userId} {
      // User can read their own profile; connected guardians can also read;
      // police can read any user profile for emergency response context.
      allow read: if isUserOwner(userId) || isGuardianOf(userId) || isPolice();
      // Only the profile owner has write capabilities
      allow write: if isUserOwner(userId);

      // 1a. Guardians Subcollection
      // Stores guardians linked to this user
      match /guardians/{guardianId} {
        // Owner can read/write their guardians list
        allow read, write: if isUserOwner(userId);
        // Guardian can read their own guardian relationship
        allow read: if isAuthenticated() && request.auth.uid == guardianId;
        // Police can read guardians for emergency context
        allow read: if isPolice();
        // Guardian can create/update relationship during invite acceptance.
        allow create, update: if
          request.resource.data.inviteId is string &&
          hasPendingInviteForPair(request.resource.data.inviteId, userId, guardianId);
      }

      // 1b. Connected Users Subcollection (for guardians)
      // Stores users that a guardian is connected to
      match /connectedUsers/{connectedUserId} {
        // Owner (guardian) can read their connected users
        allow read, write: if isUserOwner(userId);
        // The connected user can also read this relationship
        allow read: if isAuthenticated() && request.auth.uid == connectedUserId;
        // Guardian can create/update reciprocal link during invite acceptance.
        allow create, update: if
          request.resource.data.inviteId is string &&
          hasPendingInviteForPair(request.resource.data.inviteId, connectedUserId, userId);
      }

      // 1c. Location Subcollection (if used)
      match /location/{locationId} {
        // Owner can read/write their location
        allow read, write: if isUserOwner(userId);
        // Guardians can read location
        allow read: if isGuardianOf(userId);
      }
    }

    // 2. Alerts Collection
    match /alerts/{alertId} {
      // Read: owner, linked guardians, or police/authority (all alerts for police)
      allow read: if isAuthenticated() && (
        isOwner(resource.data) ||
        isGuardian(resource.data) ||
        isPolice()
      );

      // Create: only the owner can create, with required schema fields.
      // Supports ownerId (new) and userId (legacy client compatibility).
      allow create: if isAuthenticated() &&
        hasRequiredAlertCreateFields() &&
        (
          (request.resource.data.ownerId is string && request.resource.data.ownerId == request.auth.uid) ||
          (request.resource.data.userId is string && request.resource.data.userId == request.auth.uid)
        );

      // Update: tightly controlled mutable surface.
      // Allowed mutable fields preserve current lifecycle behavior while
      // enforcing owner-only cancellation.
      // Immutable security-critical fields are enforced below.
      allow update: if isAuthenticated() && (
        (
          isOwner(resource.data) &&
          onlyAllowedFieldsChanged([
            'status',
            'respondedBy',
            'respondedAt',
            'resolvedBy',
            'resolvedAt',
            'cancelledAt',
            'guardianResponse',
            'escalationLevel',
            'updatedAt'
          ])
        ) ||
        (
          isGuardian(resource.data) &&
          onlyAllowedFieldsChanged([
            'status',
            'respondedBy',
            'respondedAt',
            'resolvedBy',
            'resolvedAt',
            'guardianResponse',
            'updatedAt'
          ])
        ) ||
        (
          isPolice() &&
          onlyAllowedFieldsChanged([
            'status',
            'respondedBy',
            'respondedAt',
            'resolvedBy',
            'resolvedAt',
            'updatedAt'
          ])
        )
      ) &&
      // Only the owner may transition an alert into "cancelled" state.
      (request.resource.data.status != 'cancelled' || isOwner(resource.data)) &&
      // Immutable fields (if present) must never change.
      request.resource.data.ownerId == resource.data.ownerId &&
      request.resource.data.userId == resource.data.userId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      request.resource.data.location == resource.data.location &&
      request.resource.data.latitude == resource.data.latitude &&
      request.resource.data.longitude == resource.data.longitude &&
      request.resource.data.accuracy == resource.data.accuracy &&
      request.resource.data.alertType == resource.data.alertType &&
      request.resource.data.alertId == resource.data.alertId;

      // Delete: only owner
      allow delete: if isAuthenticated() && isOwner(resource.data);

      // 3. Alert Events Subcollection (Timeline)
      match /events/{eventId} {
        function getParentAlertOwnerId() {
          let alertData = get(/databases/$(database)/documents/alerts/$(alertId)).data;
          return alertData.ownerId != null ? alertData.ownerId : alertData.userId;
        }

        function isTimelineAuthorized() {
          let ownerId = getParentAlertOwnerId();
          // Owner of the alert
          let isOwner = request.auth.uid == ownerId;
          // Guardian of the alert owner
          let isGuardian = exists(/databases/$(database)/documents/users/$(ownerId)/guardians/$(request.auth.uid));
          return isOwner || isGuardian;
        }

        // Read: Owner or guardians can read timeline events
        allow read: if isAuthenticated() && (isTimelineAuthorized() || isPolice());

        // Write: Owner or guardians can create timeline events
        // (Cloud Functions Admin SDK bypasses these rules anyway)
        allow create: if isAuthenticated() && isTimelineAuthorized();

        // Update/Delete: Only owner can modify existing events
        allow update, delete: if isAuthenticated() && request.auth.uid == getParentAlertOwnerId();
      }

      // 3b. Audio Evidence Subcollection
      // Stores metadata for audio recordings captured during SOS alerts
      match /audioEvidence/{evidenceId} {
        function getAudioAlertOwnerId() {
          let alertData = get(/databases/$(database)/documents/alerts/$(alertId)).data;
          return alertData.ownerId != null ? alertData.ownerId : alertData.userId;
        }

        function isAudioAuthorized() {
          let ownerId = getAudioAlertOwnerId();
          let isOwner = request.auth.uid == ownerId;
          let isGuardian = exists(/databases/$(database)/documents/users/$(ownerId)/guardians/$(request.auth.uid));
          return isOwner || isGuardian;
        }

        // Only owner and guardians can read audio evidence
        allow read: if isAuthenticated() && isAudioAuthorized();

        // Only the alert owner can create audio evidence entries
        allow create: if isAuthenticated() && request.auth.uid == getAudioAlertOwnerId();

        // No update or delete from client – managed by Cloud Functions if needed
        allow update, delete: if false;
      }
    }

    // 4. Guardian Invites Collection
    match /guardianInvites/{inviteId} {
      // The sender of the invite creates it (userId is the sender)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // The receiver and the sender can query or observe the invite document
      // Match by userId (sender) or guardianEmail (receiver's email)
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.guardianEmail == request.auth.token.email
      );

      // Receiver can only mark a pending invite as accepted.
      // Bidirectional linking is performed by a Cloud Function.
      allow update: if isAuthenticated() &&
        resource.data.status == 'pending' &&
        resource.data.guardianEmail == request.auth.token.email &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.userEmail == resource.data.userEmail &&
        request.resource.data.userName == resource.data.userName &&
        request.resource.data.userPhone == resource.data.userPhone &&
        request.resource.data.guardianEmail == resource.data.guardianEmail &&
        request.resource.data.acceptedByUid == request.auth.uid &&
        request.resource.data.acceptedByEmail == request.auth.token.email &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'acceptedAt',
          'acceptedByUid',
          'acceptedByEmail'
        ]);

      // Both the sender and receiver can delete the invite
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.guardianEmail == request.auth.token.email
      );
    }

    // 5. Police Alerts Collection (Escalation)
    // Created by Cloud Functions when SOS alerts remain active past timeout
    // Cloud Functions Admin SDK bypasses these rules for writes
    match /policeAlerts/{policeAlertId} {
      // Read: Alert owner can see their own escalation status
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Read: Guardians of the alert owner can also read
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(resource.data.userId)/guardians/$(request.auth.uid));

      // Read: police/authority operators can read all police alerts
      allow read: if isPolice();

      // Police can update police alerts (assign units, close cases)
      allow update: if isPolice() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'assignedUnitId',
          'assignedAt',
          'respondedBy',
          'closedAt',
          'closedBy',
          'acknowledged',
          'updatedAt'
        ]);

      // Only Cloud Functions create/delete police alerts
      allow create, delete: if false;
    }

    // 5b. Police Units Collection
    // Managed by police dashboard for dispatch operations
    match /policeUnits/{unitId} {
      // Police can read all units
      allow read: if isPolice();

      // Police can create new units
      allow create: if isPolice();

      // Police can update unit status (dispatch, free up, etc.)
      allow update: if isPolice();

      // Police can delete units
      allow delete: if isPolice();
    }

    // 5c. Police Users Collection
    // Stores police officer profiles (used for isPolice() fallback check)
    match /policeUsers/{policeUserId} {
      // Police user can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == policeUserId;

      // Police user can write their own profile
      allow write: if isAuthenticated() && request.auth.uid == policeUserId;

      // Other police can read profiles (for team management)
      allow read: if isPolice();
    }

    // 6. Guardian Alert Inbox (delivery/ack state)
    // Created by Cloud Functions for each guardian emergency notification.
    match /guardianAlertInbox/{deliveryId} {
      // Guardian can read entries addressed to them.
      allow read: if isAuthenticated() && resource.data.guardianId == request.auth.uid;

      // Guardian can only acknowledge/transition safe mutable fields.
      allow update: if isAuthenticated() &&
        resource.data.guardianId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'pushAckAt',
          'callAcceptedAt',
          'callDeclinedAt',
          'source',
          'updatedAt'
        ]);

      // No client-side creation or deletion.
      allow create, delete: if false;
    }

    // 7. OTP Codes Collection (Phone Auth)
    // Managed entirely by Cloud Functions – no client access
    match /otpCodes/{phoneHash} {
      allow read, write: if false;
    }
  }
}
