{
  "name": "shieldher",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "test": "jest",
    "test:unit": "jest --runInBand __tests__",
    "test:integration": "jest --runInBand tests/integration",
    "test:functions": "jest --runInBand tests/functions",
    "test:rules": "jest --runInBand tests/rules",
    "test:rules:emulator": "firebase emulators:exec --only firestore --project demo-shieldher \"npm run test:rules\"",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:functions",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"App.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"App.js\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sms": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.5.0",
    "react": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "firebase-tools": "^14.22.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "metro": "^0.84.2",
    "metro-config": "^0.84.2",
    "prettier": "^3.8.1",
    "source-map": "^0.7.6"
  }
}
